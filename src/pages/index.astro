---
import '../styles/global.css';
import BioBlurb from '@/components/BioBlurb';
import LinkCard from '@/components/LinkCard';
import FAQ from '@/components/FAQ';
import fs from 'fs';
import path from 'path';
import { marked } from 'marked';

// Read and parse content files
const linksPath = path.join(process.cwd(), 'content/links.json');
const bioPath = path.join(process.cwd(), 'content/bio.md');
const faqPath = path.join(process.cwd(), 'content/faq.md');

// Parse links
const linksData = JSON.parse(fs.readFileSync(linksPath, 'utf-8'));

// Parse bio with custom YouTube embed handling
const bioMarkdown = fs.readFileSync(bioPath, 'utf-8');
const bioHtml = marked(bioMarkdown, {
  breaks: true,
});

// Parse FAQ
const faqMarkdown = fs.readFileSync(faqPath, 'utf-8');
const faqItems = faqMarkdown
  .split(/^## /m)
  .filter(Boolean)
  .map((section) => {
    const lines = section.split('\n');
    const question = lines[0].trim();
    const answerMarkdown = lines.slice(1).join('\n').trim();
    const answer = marked(answerMarkdown);
    return { question, answer };
  });
---

<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="color-scheme" content="dark" />
		<meta name="theme-color" content="#1a1a1a" />
		<title>@AyoubAbedrabbo — Quran Reading Sessions</title>
		<meta name="description" content="Join daily Quran reading sessions in English. Resources, answers, and links for those curious about Islam." />
	</head>
	<body class="bg-background text-foreground min-h-screen">
		<div class="max-w-2xl mx-auto px-4 py-16 md:py-20">
			<!-- Header / Hero -->
			<section class="mb-16 md:mb-20 text-center">
				<div class="mb-6">
					<div class="inline-block mb-4 relative">
						<div class="absolute inset-0 rounded-full bg-gradient-to-br from-accent/30 to-accent/10 blur-2xl scale-150 opacity-60"></div>
						<div class="relative w-16 h-16 mx-auto rounded-full border-2 border-accent/40 overflow-hidden bg-gradient-to-br from-accent/15 to-accent/5 flex items-center justify-center backdrop-blur-sm">
							<span class="text-3xl">☪️</span>
						</div>
					</div>
					<h1 class="text-4xl md:text-5xl font-serif font-bold text-foreground mb-2 tracking-tight">
						@AyoubAbedrabbo
					</h1>
					<p class="text-foreground/70 text-sm md:text-base leading-relaxed">
						Reading the Quran in English · TikTok Live
					</p>
				</div>

				<a
					href="https://www.tiktok.com/@ayoubabedrabbo"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-block px-5 py-2 text-xs font-medium rounded-full border border-accent/60 text-accent hover:border-accent hover:bg-accent/5 transition-all duration-300"
				>
					Follow on TikTok
				</a>
			</section>

			<!-- Bio Section -->
			<section class="mb-16">
				<BioBlurb client:load html={bioHtml} />
			</section>

			<!-- Links Section -->
			<section class="mb-16">
				<h2 class="text-3xl md:text-3xl font-serif font-bold text-foreground mb-7 tracking-tight">Resources & Links</h2>
				<div class="space-y-4">
					{linksData.map((link: any) => (
						<LinkCard
							icon={link.icon}
							title={link.title}
							description={link.description}
							href={link.url}
							youtube={link.youtube}
						/>
					))}
				</div>
			</section>

			<!-- FAQ Section -->
			<section class="mb-16">
				<h2 class="text-3xl md:text-3xl font-serif font-bold text-foreground mb-7 tracking-tight">Common Questions</h2>
				<FAQ client:load items={faqItems} />
			</section>

			<!-- Footer -->
			<footer class="pt-12 border-t border-border/20 text-center text-sm text-foreground/50">
				<p class="mb-3 text-foreground/70 font-serif tracking-wide">بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ</p>
				<p class="text-xs">© 2024 @AyoubAbedrabbo · TikTok Live</p>
			</footer>
		</div>
	</body>
</html>
