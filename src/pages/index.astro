---
import '../styles/global.css';
import LinkCard from '@/components/LinkCard.astro';
import ThemeToggle from '@/components/ThemeToggle';
import { getCollection } from 'astro:content';

const linksEntries = await getCollection('links');
const linksData = linksEntries.map((entry) => entry.data);

const streamPickLinks = linksData.filter((link) => link.variant === 'stream-pick');
const startLinks = linksData.filter((link) => link.variant === 'featured');
const resourceLinks = linksData.filter(
  (link) =>
    link.variant !== 'charity' &&
    link.variant !== 'stream-pick' &&
    link.variant !== 'featured' &&
    !link.youtube,
);
const videoLinks = linksData.filter((link) => Boolean(link.youtube));

const siteUrl = 'https://today20092.github.io/tik-tok-live-landingpage/';
const socialImageUrl = `${siteUrl}og-image.png`;
const basePath = import.meta.env.BASE_URL;
const pageDescription =
  "Read The Clear Quran online, request free English Quran copies where eligible, find Ayoub's stream edition, and watch helpful learning resources.";

const sections = [
  {
    id: 'start',
    eyebrow: 'Start here',
    title: 'Quran access',
    description: 'Read online or request an English copy.',
    links: startLinks,
  },
  {
    id: 'stream',
    eyebrow: 'On stream',
    title: 'The book Ayoub reads',
    description: 'The Clear edition used during live sessions.',
    links: streamPickLinks,
    note:
      'For spiral binding, call a local print shop and ask if they can cut the spine and bind a paperback copy.',
  },
  {
    id: 'resources',
    eyebrow: 'Learn more',
    title: 'Resources',
    description: 'Helpful places to continue studying after the live.',
    links: resourceLinks,
  },
  {
    id: 'watch',
    eyebrow: 'Watch',
    title: 'Videos and playlists',
    description: 'Tutorials and longer series for learning at your own pace.',
    links: videoLinks,
  },
].filter((section) => section.links.length > 0);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'The Clear Quran | Live with Ayoub',
  url: siteUrl,
  description: pageDescription,
  datePublished: '2026-05-02',
  dateModified: '2026-05-17',
  author: {
    '@type': 'Person',
    name: 'Ayoub Abedrabbo',
  },
  sameAs: [
    'https://www.tiktok.com/@ayoubabedrabbo',
    'https://www.twitch.tv/ayoubabedrabbo',
    'https://www.youtube.com/channel/UCQ5YfTwU5n_khZx-WJEkZKQ',
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${basePath}favicon.svg`} />
    <link rel="icon" href={`${basePath}favicon.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <title>The Clear Quran | Live with Ayoub</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={siteUrl} />
    <link rel="sitemap" type="application/xml" href={`${siteUrl}sitemap.xml`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="The Clear Quran | Live with Ayoub" />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="The Clear Quran | Live with Ayoub" />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImageUrl} />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (
        theme === 'dark' ||
        (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)
      ) {
        document.documentElement.classList.add('dark');
        document.documentElement.style.colorScheme = 'dark';
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,600&family=Nunito+Sans:opsz,wght@6..12,400;6..12,600;6..12,700;6..12,800&display=swap"
    />
  </head>
  <body>
    <a
      class="fixed top-3 left-3 z-[10000] -translate-y-4 rounded-full border border-border bg-[var(--paper)] px-3.5 py-2.5 text-sm font-black text-foreground opacity-0 no-underline transition-[opacity,transform] duration-150 focus-visible:translate-y-0 focus-visible:opacity-100 focus-visible:outline-3 focus-visible:outline-offset-3 focus-visible:outline-[color-mix(in_srgb,var(--accent),transparent_35%)]"
      href="#links"
    >
      Skip to links
    </a>
    <ThemeToggle client:load />

    <main class="relative min-h-screen overflow-x-hidden px-3 pt-3 pb-9 min-[521px]:px-4 min-[521px]:pt-7 min-[521px]:pb-12">
      <div class="ambient-grid" aria-hidden="true"></div>
      <div class="mx-auto w-full max-w-[45rem]">
        <section
          class="relative grid justify-items-center gap-3 py-3.5 text-center opacity-0 animate-hero-enter motion-reduce:opacity-100 before:pointer-events-none before:absolute before:-inset-x-4 before:-top-6 before:-bottom-1.5 before:-z-10 before:bg-[radial-gradient(ellipse_at_50%_44%,color-mix(in_srgb,var(--background),var(--paper)_58%)_0_45%,transparent_76%)] before:blur-lg min-[521px]:gap-5 min-[521px]:py-7 min-[521px]:pb-6 min-[521px]:before:-inset-x-7 min-[521px]:before:-top-10 min-[521px]:before:-bottom-2.5 motion-reduce:animate-none"
          aria-labelledby="page-title"
        >
          <div
            class="grid aspect-square w-[min(25vw,5.375rem)] place-items-center overflow-visible drop-shadow-[0_18px_28px_color-mix(in_srgb,var(--color-stone-900),transparent_84%)] min-[521px]:w-[min(34vw,7.375rem)] dark:drop-shadow-[0_18px_34px_color-mix(in_srgb,var(--color-black),transparent_74%)]"
            aria-hidden="true"
          >
            <svg
              class="hero-mark opacity-0 animate-hero-mark-enter motion-reduce:opacity-100 motion-reduce:animate-none"
              viewBox="0 0 160 160"
              xmlns="http://www.w3.org/2000/svg"
            >
              <circle class="hero-mark__halo" cx="80" cy="80" r="60" />
              <path class="hero-mark__diamond" d="M80 15 145 80 80 145 15 80Z" />
              <path
                class="hero-mark__inner"
                d="M80 31 129 80 80 129 31 80Z"
              />
              <circle class="hero-mark__dot hero-mark__dot--top" cx="80" cy="25" r="3.5" />
              <circle class="hero-mark__dot hero-mark__dot--right" cx="135" cy="80" r="3.5" />
              <circle class="hero-mark__dot hero-mark__dot--bottom" cx="80" cy="135" r="3.5" />
              <circle class="hero-mark__dot hero-mark__dot--left" cx="25" cy="80" r="3.5" />
              <text
                class="hero-mark__calligraphy"
                x="80"
                y="92"
                direction="rtl"
                text-anchor="middle"
              >
                القرآن
              </text>
            </svg>
          </div>

          <div class="grid w-full min-w-0 gap-1 min-[521px]:w-auto min-[521px]:gap-1.5">
            <p class="text-[0.68rem] leading-tight font-extrabold tracking-[0.12em] text-accent uppercase min-[521px]:text-[0.74rem] min-[521px]:tracking-[0.15em]">
              Live Quran readings and resources
            </p>
            <h1
              id="page-title"
              class="w-full max-w-[38rem] text-balance font-serif text-[clamp(2.1rem,11vw,3rem)] leading-[0.92] font-bold tracking-normal min-[521px]:text-[clamp(2.75rem,10vw,5.45rem)] min-[521px]:leading-[0.9]"
            >
              The Clear Quran
            </h1>
            <p class="text-balance font-serif text-[clamp(1.3rem,6vw,1.8rem)] leading-none font-semibold text-primary italic min-[521px]:text-[clamp(1.65rem,6vw,2.55rem)]">
              Live with Ayoub
            </p>
            <p class="mx-auto mt-1.5 w-full max-w-[29rem] text-pretty text-base leading-normal text-[var(--ink-soft)] min-[521px]:mt-2.5 min-[521px]:max-w-[32rem] min-[521px]:leading-relaxed">
              Read the translation, get the book from stream, and keep learning
              after the live.
            </p>
          </div>

          <nav
            class="mt-0 grid auto-cols-[3rem] grid-flow-col justify-center gap-2.5 min-[521px]:mt-1 min-[521px]:auto-cols-[3.25rem] min-[521px]:gap-3"
            aria-label="Social links"
          >
            <a
              class="group relative grid size-12 place-items-center rounded-full border border-border bg-[color-mix(in_srgb,var(--paper),transparent_28%)] text-foreground no-underline shadow-[0_10px_30px_color-mix(in_srgb,var(--color-stone-900),transparent_92%)] transition-[background-color,border-color,transform] duration-200 hover:-translate-y-0.5 hover:border-[color-mix(in_srgb,var(--accent),transparent_35%)] hover:bg-[var(--paper)] focus-visible:border-accent focus-visible:bg-[var(--paper)] focus-visible:outline-3 focus-visible:outline-offset-4 focus-visible:outline-[color-mix(in_srgb,var(--accent),transparent_56%)] min-[521px]:size-14 dark:bg-[color-mix(in_srgb,var(--paper),transparent_34%)]"
              href="https://www.tiktok.com/@ayoubabedrabbo"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="TikTok"
            >
              <svg class="size-6 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 1 1-2.09-2.78V9.39a6.33 6.33 0 1 0 5.54 6.27V8.69a8.16 8.16 0 0 0 4.78 1.53V6.76a4.95 4.95 0 0 1-1.01-.07Z"
                />
              </svg>
              <span class="pointer-events-none absolute -bottom-7 left-1/2 z-10 -translate-x-1/2 -translate-y-1 rounded-full border border-border bg-[var(--paper)] px-2 py-1 text-xs font-extrabold whitespace-nowrap text-foreground opacity-0 transition-[opacity,transform] duration-150 group-hover:translate-y-0 group-hover:opacity-100 group-focus-visible:translate-y-0 group-focus-visible:opacity-100">
                TikTok
              </span>
            </a>
            <a
              class="group relative grid size-12 place-items-center rounded-full border border-border bg-[color-mix(in_srgb,var(--paper),transparent_28%)] text-foreground no-underline shadow-[0_10px_30px_color-mix(in_srgb,var(--color-stone-900),transparent_92%)] transition-[background-color,border-color,transform] duration-200 hover:-translate-y-0.5 hover:border-[color-mix(in_srgb,var(--accent),transparent_35%)] hover:bg-[var(--paper)] focus-visible:border-accent focus-visible:bg-[var(--paper)] focus-visible:outline-3 focus-visible:outline-offset-4 focus-visible:outline-[color-mix(in_srgb,var(--accent),transparent_56%)] min-[521px]:size-14 dark:bg-[color-mix(in_srgb,var(--paper),transparent_34%)]"
              href="https://www.twitch.tv/ayoubabedrabbo"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Twitch"
            >
              <svg class="size-6 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M11.57 4.71h1.72v5.15h-1.72Zm4.72 0H18v5.15h-1.71ZM6 0 1.71 4.29v15.43h5.15V24l4.28-4.28h3.43L22.29 12V0Zm14.57 11.14-3.43 3.43h-3.43l-3 3v-3H6.86V1.71h13.71Z"
                />
              </svg>
              <span class="pointer-events-none absolute -bottom-7 left-1/2 z-10 -translate-x-1/2 -translate-y-1 rounded-full border border-border bg-[var(--paper)] px-2 py-1 text-xs font-extrabold whitespace-nowrap text-foreground opacity-0 transition-[opacity,transform] duration-150 group-hover:translate-y-0 group-hover:opacity-100 group-focus-visible:translate-y-0 group-focus-visible:opacity-100">
                Twitch
              </span>
            </a>
            <a
              class="group relative grid size-12 place-items-center rounded-full border border-border bg-[color-mix(in_srgb,var(--paper),transparent_28%)] text-foreground no-underline shadow-[0_10px_30px_color-mix(in_srgb,var(--color-stone-900),transparent_92%)] transition-[background-color,border-color,transform] duration-200 hover:-translate-y-0.5 hover:border-[color-mix(in_srgb,var(--accent),transparent_35%)] hover:bg-[var(--paper)] focus-visible:border-accent focus-visible:bg-[var(--paper)] focus-visible:outline-3 focus-visible:outline-offset-4 focus-visible:outline-[color-mix(in_srgb,var(--accent),transparent_56%)] min-[521px]:size-14 dark:bg-[color-mix(in_srgb,var(--paper),transparent_34%)]"
              href="https://www.youtube.com/channel/UCQ5YfTwU5n_khZx-WJEkZKQ"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="YouTube"
            >
              <svg class="size-6 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.5 3.55 12 3.55 12 3.55s-7.5 0-9.38.5A3.02 3.02 0 0 0 .5 6.19C0 8.07 0 12 0 12s0 3.93.5 5.81a3.02 3.02 0 0 0 2.12 2.14c1.88.5 9.38.5 9.38.5s7.5 0 9.38-.5a3.02 3.02 0 0 0 2.12-2.14C24 15.93 24 12 24 12s0-3.93-.5-5.81ZM9.55 15.57V8.43L15.82 12Z"
                />
              </svg>
              <span class="pointer-events-none absolute -bottom-7 left-1/2 z-10 -translate-x-1/2 -translate-y-1 rounded-full border border-border bg-[var(--paper)] px-2 py-1 text-xs font-extrabold whitespace-nowrap text-foreground opacity-0 transition-[opacity,transform] duration-150 group-hover:translate-y-0 group-hover:opacity-100 group-focus-visible:translate-y-0 group-focus-visible:opacity-100">
                YouTube
              </span>
            </a>
          </nav>
        </section>

        <section id="links" class="mt-5 grid gap-0" aria-label="Links">
          {
            sections.map((section) => (
              <section
                class="relative grid gap-5 border-t border-[color-mix(in_srgb,var(--foreground),transparent_88%)] py-8 first:border-t-0 before:absolute before:top-0 before:left-0 before:hidden before:h-px before:w-24 before:bg-[linear-gradient(90deg,var(--accent),transparent)] before:opacity-85 first:before:hidden min-[521px]:gap-6 min-[521px]:py-10 [&+section]:before:block dark:border-[color-mix(in_srgb,var(--foreground),transparent_86%)]"
                aria-labelledby={`${section.id}-heading`}
              >
                <div class="grid gap-1.5 px-0.5 pb-0.5">
                  <p class="text-[0.68rem] leading-none font-extrabold tracking-[0.16em] text-primary uppercase">
                    {section.eyebrow}
                  </p>
                  <h2
                    id={`${section.id}-heading`}
                    class="text-balance font-serif text-[clamp(1.9rem,6vw,2.25rem)] leading-[0.95] font-bold"
                  >
                    {section.title}
                  </h2>
                  <span class="mt-px max-w-xl text-[0.93rem] leading-snug text-[var(--ink-soft)]">
                    {section.description}
                  </span>
                </div>

                <div class="grid gap-3">
                  {section.links.map((link, index) => (
                    <LinkCard
                      icon={link.icon}
                      title={link.title}
                      description={link.description}
                      href={link.url}
                      youtube={link.youtube}
                      enterDelay={`${320 + index * 125}ms`}
                      variant={
                        section.eyebrow === 'Start here' && index === 0
                          ? 'primary'
                          : link.variant === 'featured'
                            ? 'default'
                            : (link.variant ?? 'default')
                      }
                    />
                  ))}
                </div>

                {
                  section.note && (
                    <p class="-mt-1 border-l-4 border-[var(--gold)] pl-3 text-[0.93rem] leading-snug text-[var(--ink-soft)]">
                      {section.note}
                    </p>
                  )
                }
              </section>
            ))
          }
        </section>

        <section
          class="grid gap-3 border-t border-[color-mix(in_srgb,var(--foreground),transparent_88%)] pt-6"
          aria-label="Site information"
        >
          <div
            id="about-page"
            class="grid scroll-mt-6 gap-1 text-[0.84rem] leading-snug text-[var(--ink-soft)]"
          >
            <p class="text-[0.62rem] leading-none font-extrabold tracking-[0.16em] text-primary uppercase">
              About this page
            </p>
            <p>
              A quick reference for reading, ordering, and learning resources
              shared during live sessions with Ayoub.
            </p>
          </div>

          <div
            id="contact-page"
            class="grid scroll-mt-6 gap-1 text-[0.84rem] leading-snug text-[var(--ink-soft)]"
          >
            <p class="text-[0.62rem] leading-none font-extrabold tracking-[0.16em] text-primary uppercase">
              Contact Ayoub
            </p>
            <p>
              Use Ayoub's public profiles on
              <a
                class="font-extrabold text-foreground underline decoration-[color-mix(in_srgb,var(--accent),transparent_48%)] decoration-2 underline-offset-3 hover:text-accent"
                href="https://www.tiktok.com/@ayoubabedrabbo">TikTok</a
              >,
              <a
                class="font-extrabold text-foreground underline decoration-[color-mix(in_srgb,var(--accent),transparent_48%)] decoration-2 underline-offset-3 hover:text-accent"
                href="https://www.twitch.tv/ayoubabedrabbo">Twitch</a
              >, or
              <a
                class="font-extrabold text-foreground underline decoration-[color-mix(in_srgb,var(--accent),transparent_48%)] decoration-2 underline-offset-3 hover:text-accent"
                href="https://www.youtube.com/channel/UCQ5YfTwU5n_khZx-WJEkZKQ">YouTube</a
              >.
            </p>
          </div>

          <div
            id="privacy-policy"
            class="grid scroll-mt-6 gap-1 text-[0.84rem] leading-snug text-[var(--ink-soft)]"
          >
            <p class="text-[0.62rem] leading-none font-extrabold tracking-[0.16em] text-primary uppercase">
              Privacy Policy
            </p>
            <p>
              This static page does not collect forms, accounts, or sign-ins.
              Outbound services apply their own policies.
            </p>
          </div>
        </section>

        <footer class="grid gap-1 py-6 pb-2 text-center text-[0.82rem] text-[var(--ink-soft)]">
          <p class="font-serif text-base font-semibold text-foreground italic">
            Bismillah ir-Rahman ir-Rahim
          </p>
          <p>For seekers, new Muslims, and anyone learning the message.</p>
        </footer>
      </div>
    </main>
  </body>
</html>
