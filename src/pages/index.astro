---
import '../styles/global.css';
import BioBlurb from '@/components/BioBlurb';
import LinkCard from '@/components/LinkCard';
import FAQ from '@/components/FAQ';
import DrawingSection from '@/components/DrawingSection';
import ThemeToggle from '@/components/ThemeToggle';
import BackToTop from '@/components/BackToTop';
import { getEntry, getCollection } from 'astro:content';
import { marked } from 'marked';

const _tileSize = 80;
const _tileCenters: [number, number][] = [
  [0, 0],
  [80, 0],
  [0, 80],
  [80, 80],
  [40, 40],
];
const _starPts = Array.from({ length: 8 }, (_, i) => {
  const oa = (i / 8) * 2 * Math.PI - Math.PI / 8;
  const ia = oa + Math.PI / 8;
  return [
    `${(28 * Math.cos(oa)).toFixed(2)},${(28 * Math.sin(oa)).toFixed(2)}`,
    `${(11.6 * Math.cos(ia)).toFixed(2)},${(11.6 * Math.sin(ia)).toFixed(2)}`,
  ].join(' ');
}).join(' ');
const _diamondPts = Array.from({ length: 4 }, (_, i) => {
  const a = (i / 4) * 2 * Math.PI + Math.PI / 4;
  return `${(11.6 * Math.cos(a)).toFixed(2)},${(11.6 * Math.sin(a)).toFixed(2)}`;
}).join(' ');

const linksEntries = await getCollection('links');
const linksData = linksEntries.map((entry) => entry.data);

const charityLinks = linksData.filter((l) => l.variant === 'charity');
const streamPickLinks = linksData.filter((l) => l.variant === 'stream-pick');
const resourceLinks = linksData.filter(
  (l) => l.variant !== 'charity' && l.variant !== 'stream-pick' && !l.youtube
);
const videoLinks = linksData.filter((l) => !!l.youtube);
const ctaLink = resourceLinks.find((l) => l.variant === 'featured') ?? resourceLinks[0];

const bioEntry = await getEntry('site', 'bio');
const bioHtml = bioEntry
  ? await marked.parse(bioEntry.body ?? '', {
      breaks: true,
    })
  : '';

const faqEntry = await getEntry('site', 'faq');
const faqItems = faqEntry
  ? await Promise.all(
      (faqEntry.body ?? '')
        .split(/^## /m)
        .filter((s) => !!s)
        .map(async (section) => {
          const lines = section.split('\n');
          const question = lines[0].trim();
          const answerMarkdown = lines.slice(1).join('\n').trim();
          const answer = await marked.parse(answerMarkdown);
          return { question, answer };
        })
    )
  : [];

const drawingsEntries = await getCollection('drawings');
const drawingsData = drawingsEntries.map((entry) => entry.data);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <link rel="icon" href="favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <meta
      name="theme-color"
      content="#f6f5f2"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#272624"
      media="(prefers-color-scheme: dark)"
    />
    <title>The Clear Quran — Live with Ayoub</title>
    <meta
      name="description"
      content="Educational resources for Islamic learning. Explore Tawhid, the Five Pillars, Quran, Hadith, and primary sources. For seekers, new Muslims, and curious learners."
    />
    <meta property="og:title" content="The Clear Quran — Live with Ayoub" />
    <meta
      property="og:description"
      content="Educational resources for Islamic learning. Explore Tawhid, the Five Pillars, Quran, Hadith, and primary sources."
    />
    <meta property="og:image" content="/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="The Clear Quran — Live with Ayoub" />
    <meta
      name="twitter:description"
      content="Educational resources for Islamic learning. Explore Tawhid, the Five Pillars, Quran, Hadith, and primary sources."
    />
    <meta name="twitter:image" content="/og-image.png" />
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (
        theme === 'dark' ||
        (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)
      ) {
        document.documentElement.classList.add('dark');
        document.documentElement.style.colorScheme = 'dark';
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Manrope:wght@400;500;600;700;800&display=swap"
    />
  </head>
  <body>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
      style="position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;opacity:.45"
    >
      <defs>
        <pattern
          id="rub-el-hizb"
          x="0"
          y="0"
          width={_tileSize}
          height={_tileSize}
          patternUnits="userSpaceOnUse"
        >
          {
            _tileCenters.map(([cx, cy]) => (
              <polygon
                points={_starPts}
                transform={`translate(${cx},${cy})`}
                fill="none"
                stroke="var(--pattern-stroke)"
                stroke-width="1"
                stroke-linejoin="round"
              />
            ))
          }
          <polygon
            points={_diamondPts}
            transform="translate(40,40)"
            fill="none"
            stroke="var(--pattern-stroke)"
            stroke-width="1"
            stroke-linejoin="round"
          />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#rub-el-hizb)"></rect>
    </svg>

    <ThemeToggle client:load />
    <BackToTop client:load />

    <main class="page-shell">
      <section class="reveal-up pt-8 md:pt-12">
        <p class="eyebrow mb-4">Live Quran reading and study resources</p>
        <h1 class="max-w-[11ch] text-5xl text-foreground md:text-6xl">
          The Clear Quran
          <span class="block text-foreground/82">Live with Ayoub</span>
        </h1>
        <p class="mt-5 max-w-[60ch] text-base leading-8 text-muted-foreground md:text-lg">
          A simple place to keep the live stream, the Quran, and supporting study material
          in one calm page.
        </p>
        <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-muted-foreground">
          <span>Live every night · 12am ET</span>
          <span class="hidden sm:inline">·</span>
          <span>TikTok, Twitch, YouTube</span>
        </div>
        <div class="mt-5 flex flex-wrap gap-5 text-sm">
          <a
            href={ctaLink?.url ?? '#resources'}
            target={ctaLink ? '_blank' : undefined}
            rel={ctaLink ? 'noopener noreferrer' : undefined}
            class="font-medium text-foreground underline decoration-border underline-offset-4 hover:decoration-foreground/50"
          >
            Open the main Quran resource
          </a>
          <a
            href="#resources"
            class="font-medium text-muted-foreground underline decoration-border underline-offset-4 hover:text-foreground"
          >
            Browse all resources
          </a>
        </div>
      </section>

      <section class="mt-10 reveal-up reveal-delay-1">
        <BioBlurb client:load html={bioHtml} />
      </section>

      <section class="mt-12 reveal-up reveal-delay-1">
        <div class="mb-4">
          <p class="eyebrow mb-2">Live links</p>
          <h2 class="text-3xl text-foreground md:text-4xl">Watch live or catch the replay</h2>
        </div>
        <div class="glass-chrome rounded-[1.4rem] px-5 md:px-6">
          <a
            href="https://www.tiktok.com/@ayoubabedrabbo"
            target="_blank"
            rel="noopener noreferrer"
            class="row-link focus-visible:ring-2 focus-visible:outline-none"
          >
            <div class="row-icon">
              <svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" fill="currentColor" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 1 1 2.03-4.96V9.75a6.34 6.34 0 1 0 4.3 6.01V8.69a8.16 8.16 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z" />
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <p class="row-meta">Watch live</p>
              <h3 class="row-title">TikTok</h3>
              <p class="row-description">Main live stream and nightly reading.</p>
            </div>
            <div class="row-arrow self-center" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                width="16"
                height="16"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M7 17 17 7" />
                <path d="M7 7h10v10" />
              </svg>
            </div>
          </a>
          <a
            href="https://www.twitch.tv/ayoubabedrabbo"
            target="_blank"
            rel="noopener noreferrer"
            class="row-link focus-visible:ring-2 focus-visible:outline-none"
          >
            <div class="row-icon">
              <svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" fill="currentColor" aria-hidden="true">
                <path d="M11.57 4.71h1.72v5.14h-1.72zm4.72 0H18v5.14h-1.71zM6 0 1.71 4.29v15.42h5.14V24l4.29-4.29h3.43L22.29 12V0Zm14.57 11.14-3.43 3.43h-3.43l-3 3v-3H6.86V1.71h13.71Z" />
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <p class="row-meta">Alternate stream</p>
              <h3 class="row-title">Twitch</h3>
              <p class="row-description">Secondary live stream if you prefer Twitch.</p>
            </div>
            <div class="row-arrow self-center" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                width="16"
                height="16"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M7 17 17 7" />
                <path d="M7 7h10v10" />
              </svg>
            </div>
          </a>
          <a
            href="https://www.youtube.com/channel/UCQ5YfTwU5n_khZx-WJEkZKQ"
            target="_blank"
            rel="noopener noreferrer"
            class="row-link focus-visible:ring-2 focus-visible:outline-none"
          >
            <div class="row-icon">
              <svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" fill="currentColor" aria-hidden="true">
                <path d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.5 3.55 12 3.55 12 3.55s-7.5 0-9.38.5A3.02 3.02 0 0 0 .5 6.19 31.24 31.24 0 0 0 0 12a31.24 31.24 0 0 0 .5 5.81 3.02 3.02 0 0 0 2.12 2.14c1.88.5 9.38.5 9.38.5s7.5 0 9.38-.5a3.02 3.02 0 0 0 2.12-2.14A31.24 31.24 0 0 0 24 12a31.24 31.24 0 0 0-.5-5.81M9.55 15.57V8.43L15.82 12Z" />
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <p class="row-meta">Replay</p>
              <h3 class="row-title">YouTube</h3>
              <p class="row-description">Catch previous sessions and follow along later.</p>
            </div>
            <div class="row-arrow self-center" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                width="16"
                height="16"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M7 17 17 7" />
                <path d="M7 7h10v10" />
              </svg>
            </div>
          </a>
        </div>
      </section>

      <section id="resources" class="mt-12 reveal-up reveal-delay-2">
        <div class="mb-4">
          <p class="eyebrow mb-2">Resources</p>
          <h2 class="text-3xl text-foreground md:text-4xl">Main study links</h2>
        </div>
        <div class="glass-chrome rounded-[1.4rem] px-5 md:px-6">
          {resourceLinks.map((link) => <LinkCard client:load {...link} />)}
        </div>
      </section>

      {streamPickLinks.length > 0 && (
        <section class="mt-12 reveal-up reveal-delay-2">
          <div class="mb-4">
            <p class="eyebrow mb-2">From the stream</p>
            <h2 class="text-3xl text-foreground md:text-4xl">Mentioned during live sessions</h2>
          </div>
          <div class="glass-chrome rounded-[1.4rem] px-5 md:px-6">
            {streamPickLinks.map((link) => <LinkCard client:load {...link} />)}
          </div>
        </section>
      )}

      {videoLinks.length > 0 && (
        <section class="mt-12 reveal-up reveal-delay-3">
          <div class="mb-4">
            <p class="eyebrow mb-2">Videos</p>
            <h2 class="text-3xl text-foreground md:text-4xl">Watch selected explanations</h2>
          </div>
          <div class="glass-chrome rounded-[1.4rem] px-5 md:px-6">
            {videoLinks.map((link) => <LinkCard client:load {...link} />)}
          </div>
        </section>
      )}

      {faqItems.length > 0 && (
        <section class="mt-12">
          <FAQ client:load items={faqItems} />
        </section>
      )}

      {drawingsData.length > 0 && (
        <section class="mt-12">
          <DrawingSection client:load items={drawingsData} />
        </section>
      )}

      {/* Giving section intentionally hidden for now.
          Preserved in data via charityLinks so it can be restored later without re-entry. */}
      {charityLinks.length > 0 && false && (
        <section class="mt-12">
          <div class="glass-chrome rounded-[1.4rem] px-5 md:px-6">
            {charityLinks.map((link) => <LinkCard client:load {...link} />)}
          </div>
        </section>
      )}

      <footer class="mt-14 pb-8 text-sm leading-7 text-muted-foreground">
        This page is meant to stay simple: live links first, resources underneath, and extra
        explanations when you want to go deeper.
      </footer>
    </main>
  </body>
</html>
