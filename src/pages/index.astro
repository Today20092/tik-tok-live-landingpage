---
import '../styles/global.css';
import LinkCard from '@/components/LinkCard';
import ThemeToggle from '@/components/ThemeToggle';
import { getCollection } from 'astro:content';

const linksEntries = await getCollection('links');
const linksData = linksEntries.map((entry) => entry.data);

const streamPickLinks = linksData.filter((link) => link.variant === 'stream-pick');
const startLinks = linksData.filter((link) => link.variant === 'featured');
const resourceLinks = linksData.filter(
  (link) =>
    link.variant !== 'charity' &&
    link.variant !== 'stream-pick' &&
    link.variant !== 'featured' &&
    !link.youtube,
);
const videoLinks = linksData.filter((link) => Boolean(link.youtube));

const siteUrl = 'https://today20092.github.io/tik-tok-live-landingpage/';
const socialImageUrl = `${siteUrl}og-image.png`;
const pageDescription =
  'A focused guide for The Clear Quran live sessions with Ayoub, including ways to read online, request an English copy, find the stream edition, watch playlists, and continue learning after the live.';

const sections = [
  {
    id: 'start',
    eyebrow: 'Start here',
    title: 'Quran access',
    description: 'Read online or request an English copy.',
    links: startLinks,
  },
  {
    id: 'stream',
    eyebrow: 'On stream',
    title: 'The book Ayoub reads',
    description: 'The Clear edition used during live sessions.',
    links: streamPickLinks,
    note:
      'For spiral binding, call a local print shop and ask if they can cut the spine and bind a paperback copy.',
  },
  {
    id: 'resources',
    eyebrow: 'Learn more',
    title: 'Resources',
    description: 'Helpful places to continue studying after the live.',
    links: resourceLinks,
  },
  {
    id: 'watch',
    eyebrow: 'Watch',
    title: 'Video playlists',
    description: 'Longer series for learning at your own pace.',
    links: videoLinks,
  },
].filter((section) => section.links.length > 0);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'The Clear Quran | Live with Ayoub',
  url: siteUrl,
  description: pageDescription,
  datePublished: '2026-05-02',
  dateModified: '2026-05-02',
  author: {
    '@type': 'Person',
    name: 'Ayoub Abedrabbo',
  },
  sameAs: [
    'https://www.tiktok.com/@ayoubabedrabbo',
    'https://www.twitch.tv/ayoubabedrabbo',
    'https://www.youtube.com/channel/UCQ5YfTwU5n_khZx-WJEkZKQ',
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <title>The Clear Quran | Live with Ayoub</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={siteUrl} />
    <link rel="sitemap" type="application/xml" href={`${siteUrl}sitemap.xml`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="The Clear Quran | Live with Ayoub" />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="The Clear Quran | Live with Ayoub" />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImageUrl} />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (
        theme === 'dark' ||
        (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)
      ) {
        document.documentElement.classList.add('dark');
        document.documentElement.style.colorScheme = 'dark';
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,600&family=Nunito+Sans:opsz,wght@6..12,400;6..12,600;6..12,700;6..12,800&display=swap"
    />
  </head>
  <body>
    <a class="skip-link" href="#links">Skip to links</a>
    <ThemeToggle client:load />

    <main class="linktree-shell">
      <div class="ambient-grid" aria-hidden="true"></div>
      <div class="page-wrap">
        <section class="profile-hero" aria-labelledby="page-title">
          <div class="art-panel" aria-hidden="true">
            <svg
              class="hero-mark"
              viewBox="0 0 160 160"
              xmlns="http://www.w3.org/2000/svg"
            >
              <circle class="hero-mark__halo" cx="80" cy="80" r="60" />
              <path class="hero-mark__diamond" d="M80 15 145 80 80 145 15 80Z" />
              <path
                class="hero-mark__inner"
                d="M80 31 129 80 80 129 31 80Z"
              />
              <circle class="hero-mark__dot hero-mark__dot--top" cx="80" cy="25" r="3.5" />
              <circle class="hero-mark__dot hero-mark__dot--right" cx="135" cy="80" r="3.5" />
              <circle class="hero-mark__dot hero-mark__dot--bottom" cx="80" cy="135" r="3.5" />
              <circle class="hero-mark__dot hero-mark__dot--left" cx="25" cy="80" r="3.5" />
              <text
                class="hero-mark__calligraphy"
                x="80"
                y="92"
                direction="rtl"
                text-anchor="middle"
              >
                القرآن
              </text>
            </svg>
          </div>

          <div class="profile-copy">
            <p class="kicker">Live Quran readings and resources</p>
            <h1 id="page-title">The Clear Quran</h1>
            <p class="subtitle">Live with Ayoub</p>
            <p class="intro">
              Read the translation, get the book from stream, and keep learning
              after the live.
            </p>
          </div>

          <nav class="social-row" aria-label="Social links">
            <a
              href="https://www.tiktok.com/@ayoubabedrabbo"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="TikTok"
              data-label="TikTok"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 1 1-2.09-2.78V9.39a6.33 6.33 0 1 0 5.54 6.27V8.69a8.16 8.16 0 0 0 4.78 1.53V6.76a4.95 4.95 0 0 1-1.01-.07Z"
                />
              </svg>
            </a>
            <a
              href="https://www.twitch.tv/ayoubabedrabbo"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Twitch"
              data-label="Twitch"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M11.57 4.71h1.72v5.15h-1.72Zm4.72 0H18v5.15h-1.71ZM6 0 1.71 4.29v15.43h5.15V24l4.28-4.28h3.43L22.29 12V0Zm14.57 11.14-3.43 3.43h-3.43l-3 3v-3H6.86V1.71h13.71Z"
                />
              </svg>
            </a>
            <a
              href="https://www.youtube.com/channel/UCQ5YfTwU5n_khZx-WJEkZKQ"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="YouTube"
              data-label="YouTube"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.5 3.55 12 3.55 12 3.55s-7.5 0-9.38.5A3.02 3.02 0 0 0 .5 6.19C0 8.07 0 12 0 12s0 3.93.5 5.81a3.02 3.02 0 0 0 2.12 2.14c1.88.5 9.38.5 9.38.5s7.5 0 9.38-.5a3.02 3.02 0 0 0 2.12-2.14C24 15.93 24 12 24 12s0-3.93-.5-5.81ZM9.55 15.57V8.43L15.82 12Z"
                />
              </svg>
            </a>
          </nav>
        </section>

        <section id="links" class="links-stack" aria-label="Links">
          {
            sections.map((section) => (
              <section class="link-section" aria-labelledby={`${section.id}-heading`}>
                <div class="section-heading">
                  <p>{section.eyebrow}</p>
                  <h2 id={`${section.id}-heading`}>{section.title}</h2>
                  <span>{section.description}</span>
                </div>

                <div class="link-list">
                  {section.links.map((link, index) => (
                    <LinkCard
                      client:load
                      icon={link.icon}
                      title={link.title}
                      description={link.description}
                      href={link.url}
                      youtube={link.youtube}
                      variant={
                        section.eyebrow === 'Start here' && index === 0
                          ? 'primary'
                          : link.variant === 'featured'
                            ? 'default'
                            : (link.variant ?? 'default')
                      }
                    />
                  ))}
                </div>

                {section.note && <p class="section-note">{section.note}</p>}
              </section>
            ))
          }
        </section>

        <section class="site-info" aria-label="Site information">
          <div id="about-page" class="site-info__item">
            <p class="site-info__label">About this page</p>
            <p>
              A quick reference for reading, ordering, and learning resources
              shared during live sessions with Ayoub.
            </p>
          </div>

          <div id="contact-page" class="site-info__item">
            <p class="site-info__label">Contact Ayoub</p>
            <p>
              Use Ayoub's public profiles on
              <a href="https://www.tiktok.com/@ayoubabedrabbo">TikTok</a>,
              <a href="https://www.twitch.tv/ayoubabedrabbo">Twitch</a>, or
              <a href="https://www.youtube.com/channel/UCQ5YfTwU5n_khZx-WJEkZKQ">YouTube</a>.
            </p>
          </div>

          <div id="privacy-policy" class="site-info__item">
            <p class="site-info__label">Privacy Policy</p>
            <p>
              This static page does not collect forms, accounts, or sign-ins.
              Outbound services apply their own policies.
            </p>
          </div>
        </section>

        <footer class="site-footer">
          <p class="arabic-line">Bismillah ir-Rahman ir-Rahim</p>
          <p>For seekers, new Muslims, and anyone learning the message.</p>
        </footer>
      </div>
    </main>
  </body>
</html>
