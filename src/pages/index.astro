---
import '../styles/global.css';
import BioBlurb from '@/components/BioBlurb';
import LinkCard from '@/components/LinkCard';
import FAQ from '@/components/FAQ';
import DrawingSection from '@/components/DrawingSection';
import ThemeToggle from '@/components/ThemeToggle';
import BackToTop from '@/components/BackToTop';
import { getEntry, getCollection } from 'astro:content';
import { marked } from 'marked';

// Islamic geometric background — 8-pointed star (Rub el Hizb) grid
// Square tile: 80×80, star outer R=28, inner r=11.6 (ratio ~0.414 for 45° geometry)
const _tileSize = 80;
const _tileCenters: [number, number][] = [
  [0, 0], [80, 0], [0, 80], [80, 80], [40, 40]
];
// 8-pointed star: alternate outer (R=28) and inner (r=11.6) vertices at 45° steps
const _starPts = Array.from({ length: 8 }, (_, i) => {
  const oa = (i / 8) * 2 * Math.PI - Math.PI / 8;
  const ia = oa + Math.PI / 8;
  return [
    `${(28 * Math.cos(oa)).toFixed(2)},${(28 * Math.sin(oa)).toFixed(2)}`,
    `${(11.6 * Math.cos(ia)).toFixed(2)},${(11.6 * Math.sin(ia)).toFixed(2)}`,
  ].join(' ');
}).join(' ');
// Rotated square (45° diamond) at center, connecting stars — vertices at distance 11.6
const _diamondPts = Array.from({ length: 4 }, (_, i) => {
  const a = (i / 4) * 2 * Math.PI + Math.PI / 4;
  return `${(11.6 * Math.cos(a)).toFixed(2)},${(11.6 * Math.sin(a)).toFixed(2)}`;
}).join(' ');

// Fetch links
const linksEntries = await getCollection('links');
const linksData = linksEntries.map((entry) => entry.data);

// Parse bio with custom YouTube embed handling
const bioEntry = await getEntry('site', 'bio');
const bioHtml = bioEntry ? await marked.parse(bioEntry.body ?? '', {
  breaks: true,
}) : '';

// Parse FAQ
const faqEntry = await getEntry('site', 'faq');
const faqItems = faqEntry ? await Promise.all(
  (faqEntry.body ?? '')
    .split(/^## /m)
    .filter((s) => !!s)
    .map(async (section) => {
      const lines = section.split('\n');
      const question = lines[0].trim();
      const answerMarkdown = lines.slice(1).join('\n').trim();
      const answer = await marked.parse(answerMarkdown);
      return { question, answer };
    })
) : [];

// Fetch drawings
const drawingsEntries = await getCollection('drawings');
const drawingsData = drawingsEntries.map((entry) => entry.data);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <link rel="icon" href="favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <meta
      name="theme-color"
      content="#F4F3EF"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#1F1F1F"
      media="(prefers-color-scheme: dark)"
    />
    <title>The Clear Quran — Live with Ayoub</title>
    <meta
      name="description"
      content="Educational resources for Islamic learning. Explore Tawhid, the Five Pillars, Quran, Hadith, and primary sources. For seekers, new Muslims, and curious learners."
    />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta
      property="og:title"
      content="The Clear Quran — Live with Ayoub"
    />
    <meta
      property="og:description"
      content="Educational resources for Islamic learning. Explore Tawhid, the Five Pillars, Quran, Hadith, and primary sources. For seekers, new Muslims, and curious learners."
    />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="The Clear Quran — Live with Ayoub"
    />
    <meta
      name="twitter:description"
      content="Educational resources for Islamic learning. Explore Tawhid, the Five Pillars, Quran, Hadith, and primary sources. For seekers, new Muslims, and curious learners."
    />
    <meta name="twitter:image" content="/og-image.png" />
    <script is:inline>
      // Prevent flash of wrong theme by applying theme before render
      const theme = localStorage.getItem('theme');
      if (
        theme === 'dark' ||
        (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)
      ) {
        document.documentElement.classList.add('dark');
        document.documentElement.style.colorScheme = 'dark';
      }
    </script>
  </head>
  <body class="bg-background text-foreground min-h-screen">
    <!-- 8-pointed star (Rub el Hizb) Islamic geometric background -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
      style="position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;opacity:1"
    >
      <defs>
        <pattern
          id="rub-el-hizb"
          x="0"
          y="0"
          width={_tileSize}
          height={_tileSize}
          patternUnits="userSpaceOnUse"
        >
          {
            _tileCenters.map(([cx, cy]) => (
              <polygon
                points={_starPts}
                transform={`translate(${cx},${cy})`}
                fill="none"
                stroke="var(--pattern-stroke)"
                stroke-width="1.2"
                stroke-linejoin="round"
              />
            ))
          }
          <polygon
            points={_diamondPts}
            transform="translate(40,40)"
            fill="none"
            stroke="var(--pattern-stroke)"
            stroke-width="1.2"
            stroke-linejoin="round"
          />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#rub-el-hizb)"></rect>
    </svg>
    <ThemeToggle client:load />
    <BackToTop client:load />
    <!-- Sticky mobile CTA -->
    <div class="md:hidden fixed bottom-0 left-0 right-0 z-50 p-3 bg-background/90 backdrop-blur border-t border-border/20">
      <a
        href="https://www.onemessagefoundation.com/free-quran/p/quran-english"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-accent text-background hover:bg-accent/90 block w-full rounded-full py-3 text-center text-sm font-medium transition-all duration-300"
      >
        Get the Free Quran →
      </a>
    </div>

    <div
      class="relative mx-auto max-w-2xl px-4 py-16 pb-24 md:py-20 md:pb-20"
      style="z-index:1"
    >
      <!-- Header / Hero -->
      <section class="hero-fadein mb-16 text-center md:mb-20">
        <div class="mb-6">
          <div class="mb-8 inline-block">
            <!-- Clean, High-Fidelity Crescent & Star -->
            <svg 
              viewBox="0 0 24 24" 
              class="text-accent relative h-16 w-16 md:h-20 md:w-20"
              fill="currentColor"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path d="M12 2C10.5 2 9.1 2.3 7.8 2.8C9.7 4.2 10.9 6.4 10.9 9C10.9 11.6 9.7 13.8 7.8 15.2C9.1 15.7 10.5 16 12 16C15.9 16 19 12.9 19 9C19 5.1 15.9 2 12 2Z" />
              <path d="M18.5 2L18.8 3L19.8 3.3L18.8 3.6L18.5 4.6L18.2 3.6L17.2 3.3L18.2 3L18.5 2Z" />
              <path d="M15 4L15.4 5.4L16.8 5.8L15.4 6.2L15 7.6L14.6 6.2L13.2 5.8L14.6 5.4L15 4Z" />
            </svg>
          </div>
          <h1
            class="text-foreground mb-2 font-serif text-4xl font-bold tracking-tight md:text-6xl"
          >
            The Clear Quran
            <span class="text-accent block text-3xl md:text-5xl">Live with Ayoub</span>
          </h1>
          <p class="text-foreground/70 text-base leading-relaxed md:text-lg">
            Join nightly Quran readings on TikTok — open to everyone
          </p>
        </div>

        <!-- Trust bar -->
        <div class="text-foreground/55 mb-5 flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-xs">
          <span>📱 TikTok Live · <a href="https://www.tiktok.com/@ayoubabedrabbo" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">@ayoubabedrabbo</a></span>
          <span class="text-foreground/30">·</span>
          <span>Free resources</span>
          <span class="text-foreground/30">·</span>
          <span>No signup required</span>
        </div>

        <div class="flex flex-wrap items-center justify-center gap-3">
          <a
            href="#resources"
            class="bg-accent text-background hover:bg-accent/90 inline-block rounded-full px-6 py-2.5 text-sm font-medium transition-all duration-300"
          >
            Explore Resources ↓
          </a>
          <a
            href="https://www.tiktok.com/@ayoubabedrabbo"
            target="_blank"
            rel="noopener noreferrer"
            class="border-foreground/20 text-foreground/60 hover:border-foreground/40 hover:text-foreground/80 inline-flex items-center gap-1.5 rounded-full border px-5 py-2 text-xs font-medium transition-all duration-300"
          >
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
            </svg>
            Watch Live
          </a>
        </div>
      </section>

      <!-- Bio Section -->
      <section class="mb-12">
        <BioBlurb client:load html={bioHtml} />
      </section>

      <hr class="border-border/20 mb-12" />

      <!-- Links Section -->
      <section id="resources" class="mb-20">
        <div class="mb-8">
          <h2
            class="text-foreground mb-2 font-serif text-3xl font-bold tracking-tight md:text-4xl"
          >
            Get the Book & Learn More
          </h2>
          <p class="text-foreground/55 text-sm leading-relaxed">
            Get your copy of the Quran, read it online, and explore resources to go deeper.
          </p>
        </div>
        <div class="flex flex-col gap-4">
          {
            linksData.map((link, i) => (
              <LinkCard
                client:load
                icon={link.icon}
                title={link.title}
                description={link.description}
                href={link.url}
                youtube={link.youtube}
                variant={link.variant ?? (i === 1 || i === 2 ? 'featured' : 'default')}
              />
            ))
          }
        </div>
      </section>

      <hr class="border-border/20 mb-20" />

      <!-- FAQ Section -->
      <section class="mb-20">
        <FAQ
          client:load
          title="The Why: Understanding Islamic Concepts"
          items={faqItems}
        />
      </section>

      <hr class="border-border/20 mb-20" />

      <!-- Drawings Section -->
      <section class="mb-20">
        <DrawingSection client:load items={drawingsData} />
      </section>

      <!-- Footer -->
      <footer
        class="border-border/20 text-foreground/50 border-t pt-12 text-center text-sm"
      >
        <!-- Social Links -->
        <div class="mb-5 flex items-center justify-center gap-5">
          <a
            href="https://www.tiktok.com/@ayoubabedrabbo"
            target="_blank"
            rel="noopener noreferrer"
            class="text-foreground/50 hover:text-accent transition-colors duration-300"
            aria-label="TikTok"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
            </svg>
          </a>
        </div>
        <p class="text-foreground/70 mb-3 font-serif tracking-wide">
          بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ
        </p>
        <p class="text-xs">
          © 2026 Islamic Education Resource · For Seekers and Learners
        </p>
      </footer>
    </div>
  </body>
</html>
