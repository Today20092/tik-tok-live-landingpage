---
import '../styles/global.css';
import LinkCard from '@/components/LinkCard';
import ThemeToggle from '@/components/ThemeToggle';
import { getCollection } from 'astro:content';

const linksEntries = await getCollection('links');
const linksData = linksEntries.map((entry) => entry.data);

const streamPickLinks = linksData.filter((link) => link.variant === 'stream-pick');
const startLinks = linksData.filter((link) => link.variant === 'featured');
const resourceLinks = linksData.filter(
  (link) =>
    link.variant !== 'charity' &&
    link.variant !== 'stream-pick' &&
    link.variant !== 'featured' &&
    !link.youtube,
);
const videoLinks = linksData.filter((link) => Boolean(link.youtube));

const sections = [
  {
    eyebrow: 'Start here',
    title: 'Quran access',
    description: 'Read online or request a copy in English.',
    links: startLinks,
  },
  {
    eyebrow: 'On stream',
    title: 'The book Ayoub reads',
    description: 'The Clear Quran edition used during live sessions.',
    links: streamPickLinks,
    note:
      'For spiral binding, call a local print shop and ask if they can cut the spine and bind a paperback copy.',
  },
  {
    eyebrow: 'Learn more',
    title: 'Resources',
    description: 'Helpful places to continue studying after the live.',
    links: resourceLinks,
  },
  {
    eyebrow: 'Watch',
    title: 'Video playlists',
    description: 'Longer series for learning at your own pace.',
    links: videoLinks,
  },
].filter((section) => section.links.length > 0);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#F7F0E6" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#102620" media="(prefers-color-scheme: dark)" />
    <title>The Clear Quran | Live with Ayoub</title>
    <meta
      name="description"
      content="A simple link tree for The Clear Quran live sessions with Ayoub. Read, order, watch, and explore Quran resources."
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="The Clear Quran | Live with Ayoub" />
    <meta
      property="og:description"
      content="Read, order, watch, and explore Quran resources from the live sessions."
    />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="The Clear Quran | Live with Ayoub" />
    <meta
      name="twitter:description"
      content="Read, order, watch, and explore Quran resources from the live sessions."
    />
    <meta name="twitter:image" content="/og-image.png" />
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (
        theme === 'dark' ||
        (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)
      ) {
        document.documentElement.classList.add('dark');
        document.documentElement.style.colorScheme = 'dark';
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,600&family=Nunito+Sans:opsz,wght@6..12,400;6..12,600;6..12,700;6..12,800&display=swap"
    />
  </head>
  <body>
    <ThemeToggle client:load />

    <main class="linktree-shell">
      <div class="ambient-grid" aria-hidden="true"></div>
      <div class="page-wrap">
        <section class="profile-hero" aria-labelledby="page-title">
          <a href="#links" class="art-panel" aria-label="Skip to links">
            <svg
              class="hero-mark"
              viewBox="0 0 160 160"
              role="img"
              aria-label="The Clear Quran"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                class="hero-mark__arch"
                d="M28 134V70C28 41.3 51.3 18 80 18s52 23.3 52 52v64H28Z"
              />
              <path
                class="hero-mark__star"
                d="M80 35 86.6 55.8 108 56 90.8 68.5 97.2 89 80 76.8 62.8 89 69.2 68.5 52 56 73.4 55.8 80 35Z"
              />
              <path
                class="hero-mark__book"
                d="M42 92c15-9 28-9 38 0 10-9 23-9 38 0v33c-15-8-28-8-38 1-10-9-23-9-38-1V92Z"
              />
              <path
                class="hero-mark__book-line"
                d="M80 92v34M50 101c9-3.7 17.7-3.2 26 1.5M110 101c-9-3.7-17.7-3.2-26 1.5"
              />
              <path class="hero-mark__moon" d="M107 42a17 17 0 1 0 0 34 22 22 0 1 1 0-34Z" />
            </svg>
          </a>

          <div class="profile-copy">
            <p class="kicker">Live Quran readings and resources</p>
            <h1 id="page-title">The Clear Quran</h1>
            <p class="subtitle">Live with Ayoub</p>
            <p class="intro">
              The quickest place to find the Quran, the book from stream, study
              resources, and the main places to follow.
            </p>
          </div>

          <nav class="social-row" aria-label="Social links">
            <a
              href="https://www.tiktok.com/@ayoubabedrabbo"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="TikTok"
              data-label="TikTok"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 1 1-2.09-2.78V9.39a6.33 6.33 0 1 0 5.54 6.27V8.69a8.16 8.16 0 0 0 4.78 1.53V6.76a4.95 4.95 0 0 1-1.01-.07Z"
                />
              </svg>
            </a>
            <a
              href="https://www.twitch.tv/ayoubabedrabbo"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Twitch"
              data-label="Twitch"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M11.57 4.71h1.72v5.15h-1.72Zm4.72 0H18v5.15h-1.71ZM6 0 1.71 4.29v15.43h5.15V24l4.28-4.28h3.43L22.29 12V0Zm14.57 11.14-3.43 3.43h-3.43l-3 3v-3H6.86V1.71h13.71Z"
                />
              </svg>
            </a>
            <a
              href="https://www.youtube.com/channel/UCQ5YfTwU5n_khZx-WJEkZKQ"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="YouTube"
              data-label="YouTube"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.5 3.55 12 3.55 12 3.55s-7.5 0-9.38.5A3.02 3.02 0 0 0 .5 6.19C0 8.07 0 12 0 12s0 3.93.5 5.81a3.02 3.02 0 0 0 2.12 2.14c1.88.5 9.38.5 9.38.5s7.5 0 9.38-.5a3.02 3.02 0 0 0 2.12-2.14C24 15.93 24 12 24 12s0-3.93-.5-5.81ZM9.55 15.57V8.43L15.82 12Z"
                />
              </svg>
            </a>
          </nav>
        </section>

        <section id="links" class="links-stack" aria-label="Links">
          {
            sections.map((section) => (
              <section class="link-section" aria-labelledby={`${section.eyebrow}-heading`}>
                <div class="section-heading">
                  <p>{section.eyebrow}</p>
                  <h2 id={`${section.eyebrow}-heading`}>{section.title}</h2>
                  <span>{section.description}</span>
                </div>

                <div class="link-list">
                  {section.links.map((link) => (
                    <LinkCard
                      client:load
                      icon={link.icon}
                      title={link.title}
                      description={link.description}
                      href={link.url}
                      youtube={link.youtube}
                      variant={link.variant ?? 'default'}
                    />
                  ))}
                </div>

                {section.note && <p class="section-note">{section.note}</p>}
              </section>
            ))
          }
        </section>

        <footer class="site-footer">
          <p class="arabic-line">Bismillah ir-Rahman ir-Rahim</p>
          <p>For seekers, new Muslims, and anyone learning the Quran.</p>
        </footer>
      </div>
    </main>
  </body>
</html>
